<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="JustMeetinPoint.Maui.Features.Auth.Views.LoginView"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="#F3F6FB">

    <ScrollView>
        <Grid Padding="28"
              RowDefinitions="Auto,Auto">

            <VerticalStackLayout Grid.Row="0"
                                 Margin="0,48,0,28"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="16">

                <Image Source="app_logo.svg"
                       WidthRequest="96"
                       HeightRequest="96"
                       Aspect="AspectFit" />

                <Label Text="Just Meeting Point"
                       FontSize="30"
                       FontAttributes="Bold"
                       TextColor="#1F1F1F"
                       HorizontalTextAlignment="Center" />

                <Label Text="Encuentra el punto justo para todos"
                       FontSize="16"
                       TextColor="#5F6368"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <Border Grid.Row="1"
                    BackgroundColor="#FFFFFF"
                    Stroke="#E3E7EE"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 24"
                    Padding="20">

                <VerticalStackLayout Spacing="14">

                    <Label Text="Iniciar sesión"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#1F1F1F" />

                    <Label Text="Accede para continuar"
                           FontSize="14"
                           TextColor="#5F6368" />

                    <Border
                        Margin="0,8,0,0"
                        BackgroundColor="#FFFFFF"
                        Stroke="#DADCE0"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 14"
                        Padding="14,4">
                        <Entry Placeholder="Correo electrónico"
                               Text="{Binding Email}"
                               Keyboard="Email"
                               TextColor="#1F1F1F"
                               PlaceholderColor="#5F6368"
                               BackgroundColor="Transparent" />
                    </Border>

                    <Border
                        BackgroundColor="#FFFFFF"
                        Stroke="#DADCE0"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 14"
                        Padding="14,4">
                        <Entry Placeholder="Contraseña"
                               Text="{Binding Password}"
                               IsPassword="True"
                               TextColor="#1F1F1F"
                               PlaceholderColor="#5F6368"
                               BackgroundColor="Transparent" />
                    </Border>

                    <Label Text="{Binding Message}"
                           TextColor="#D93025"
                           FontSize="14"
                           LineBreakMode="WordWrap" />

                    <Button Text="Iniciar sesión"
                            Margin="0,8,0,0"
                            HeightRequest="54"
                            BackgroundColor="#1A73E8"
                            TextColor="White"
                            CornerRadius="14"
                            Command="{Binding LoginCommand}" />

                    <Button Text="Crear cuenta"
                            HeightRequest="54"
                            BackgroundColor="#FFFFFF"
                            TextColor="#1A73E8"
                            BorderColor="#DADCE0"
                            BorderWidth="1"
                            CornerRadius="14"
                            Command="{Binding GoToRegisterCommand}" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>