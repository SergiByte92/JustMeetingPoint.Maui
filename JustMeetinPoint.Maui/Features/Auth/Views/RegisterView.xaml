<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="JustMeetinPoint.Maui.Features.Auth.Views.RegisterView"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False"
    BackgroundColor="#F3F4F6">

    <ScrollView>
        <Grid
            Padding="28"
            RowDefinitions="Auto,Auto">

            <!-- BRAND HEADER -->
            <VerticalStackLayout
                Grid.Row="0"
                Margin="0,32,0,24"
                HorizontalOptions="Center"
                Spacing="14">

                <Image
                    Source="app_logo.png"
                    WidthRequest="96"
                    HeightRequest="96"
                    Aspect="AspectFit"
                    HorizontalOptions="Center" />

                <Label
                    Text="Just Meeting Point"
                    FontSize="30"
                    FontAttributes="Bold"
                    TextColor="#0B57D0"
                    HorizontalTextAlignment="Center" />

                <Label
                    Text="Crea tu cuenta para empezar a organizar quedadas."
                    FontSize="15"
                    TextColor="#5F6368"
                    HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- REGISTER CARD -->
            <Border
                Grid.Row="1"
                BackgroundColor="#FFFFFF"
                Stroke="#E5E7EB"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24"
                Padding="20">

                <VerticalStackLayout Spacing="14">

                    <VerticalStackLayout Spacing="4">
                        <Label
                            Text="Crear cuenta"
                            FontSize="22"
                            FontAttributes="Bold"
                            TextColor="#202124" />

                        <Label
                            Text="Completa tus datos básicos."
                            FontSize="14"
                            TextColor="#5F6368" />
                    </VerticalStackLayout>

                    <!-- USERNAME -->
                    <Border
                        Margin="0,8,0,0"
                        BackgroundColor="#FFFFFF"
                        Stroke="#D2E3FC"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        Padding="14,4">

                        <Entry
                            Placeholder="Nombre"
                            Text="{Binding Username}"
                            TextColor="#202124"
                            PlaceholderColor="#5F6368"
                            BackgroundColor="Transparent"
                            HeightRequest="48" />
                    </Border>

                    <!-- EMAIL -->
                    <Border
                        BackgroundColor="#FFFFFF"
                        Stroke="#D2E3FC"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        Padding="14,4">

                        <Entry
                            Placeholder="Correo electrónico"
                            Text="{Binding Email}"
                            Keyboard="Email"
                            TextColor="#202124"
                            PlaceholderColor="#5F6368"
                            BackgroundColor="Transparent"
                            HeightRequest="48" />
                    </Border>

                    <!-- BIRTH DATE -->
                    <Border
                        BackgroundColor="#FFFFFF"
                        Stroke="#D2E3FC"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        Padding="14,4">

                        <DatePicker
                            Date="{Binding BirthDate}"
                            TextColor="#202124"
                            BackgroundColor="Transparent"
                            Format="dd/MM/yyyy"
                            MaximumDate="2008-12-31"
                            HeightRequest="48" />
                    </Border>

                    <!-- PASSWORD -->
                    <Border
                        BackgroundColor="#FFFFFF"
                        Stroke="#D2E3FC"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        Padding="14,4">

                        <Entry
                            Placeholder="Contraseña"
                            Text="{Binding Password}"
                            IsPassword="True"
                            TextColor="#202124"
                            PlaceholderColor="#5F6368"
                            BackgroundColor="Transparent"
                            HeightRequest="48" />
                    </Border>

                    <!-- REPEAT PASSWORD -->
                    <Border
                        BackgroundColor="#FFFFFF"
                        Stroke="#D2E3FC"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        Padding="14,4">

                        <Entry
                            Placeholder="Confirmar contraseña"
                            Text="{Binding RepeatPassword}"
                            IsPassword="True"
                            TextColor="#202124"
                            PlaceholderColor="#5F6368"
                            BackgroundColor="Transparent"
                            HeightRequest="48" />
                    </Border>

                    <!-- MESSAGE -->
                    <Label
                        Text="{Binding Message}"
                        TextColor="#D93025"
                        FontSize="13"
                        LineBreakMode="WordWrap" />

                    <!-- CTA -->
                    <Button
                        Text="Crear cuenta"
                        Margin="0,8,0,0"
                        Command="{Binding RegisterCommand}"
                        HeightRequest="52"
                        BackgroundColor="#1A73E8"
                        TextColor="#FFFFFF"
                        FontAttributes="Bold"
                        CornerRadius="16" />

                </VerticalStackLayout>
            </Border>

        </Grid>
    </ScrollView>
</ContentPage>