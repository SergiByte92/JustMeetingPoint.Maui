<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="JustMeetinPoint.Maui.Features.Dashboard.Views.HomeView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:JustMeetinPoint.Maui.Features.Dashboard.ViewModels"
    x:DataType="vm:HomeViewModel"
    Title="Inicio"
    BackgroundColor="#F3F4F6">

    <ContentPage.Resources>

        <Style x:Key="M3ElevatedCard" TargetType="Border">
            <Setter Property="BackgroundColor" Value="#FFFFFF" />
            <Setter Property="StrokeThickness" Value="0" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="StrokeShape">
                <Setter.Value>
                    <RoundRectangle CornerRadius="16" />
                </Setter.Value>
            </Setter>
            <Setter Property="Shadow">
                <Setter.Value>
                    <Shadow Brush="#000000"
                            Opacity="0.08"
                            Offset="0,3"
                            Radius="8" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="M3OutlinedCard" TargetType="Border">
            <Setter Property="BackgroundColor" Value="#FFFFFF" />
            <Setter Property="Stroke" Value="#E5E7EB" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="StrokeShape">
                <Setter.Value>
                    <RoundRectangle CornerRadius="16" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="M3PrimaryButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#0B2545" />
            <Setter Property="TextColor" Value="#FFFFFF" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="HeightRequest" Value="48" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="M3SecondaryText" TargetType="Label">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextColor" Value="#64748B" />
            <Setter Property="LineBreakMode" Value="WordWrap" />
        </Style>

    </ContentPage.Resources>

    <Grid RowDefinitions="*">

        <ScrollView>
            <VerticalStackLayout Padding="16,20,16,28" Spacing="16">

                <!-- SALUDO -->
                <VerticalStackLayout Spacing="4">
                    <Label
                        Text="{Binding GreetingText}"
                        FontSize="28"
                        FontAttributes="Bold"
                        TextColor="#0B2545" />

                    <Label
                        Text="{Binding SubtitleText}"
                        Style="{StaticResource M3SecondaryText}" />
                </VerticalStackLayout>

                <!-- ERROR -->
                <Border
                    Style="{StaticResource M3OutlinedCard}"
                    IsVisible="{Binding HasError}"
                    BackgroundColor="#FFF7F7"
                    Stroke="#FCA5A5">

                    <Label
                        Text="{Binding ErrorMessage}"
                        FontSize="13"
                        TextColor="#B91C1C" />
                </Border>

                <!-- CTA PRINCIPAL -->
                <Border Style="{StaticResource M3ElevatedCard}">
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">

                        <VerticalStackLayout Grid.Row="0" Spacing="6">
                            <Label
                                Text="{Binding MainCtaTitle}"
                                FontSize="20"
                                FontAttributes="Bold"
                                TextColor="#202124" />

                            <Label
                                Text="{Binding MainCtaSubtitle}"
                                Style="{StaticResource M3SecondaryText}" />
                        </VerticalStackLayout>

                        <Button
                            Grid.Row="1"
                            Text="{Binding PrimaryButtonText}"
                            Style="{StaticResource M3PrimaryButton}"
                            Command="{Binding GoToActiveGroupCommand}" />

                        <ActivityIndicator
                            Grid.Row="2"
                            IsRunning="{Binding IsBusy}"
                            IsVisible="{Binding IsBusy}"
                            Color="#0B2545"
                            HorizontalOptions="Center" />

                    </Grid>
                </Border>

                <!-- VALUE CARDS -->
                <VerticalStackLayout Spacing="12">

                    <Label
        Text="Para una quedada perfecta"
        FontSize="17"
        FontAttributes="Bold"
        TextColor="#0B2545" />

                    <Grid
        ColumnDefinitions="*,*,*"
        ColumnSpacing="10">

                        <!-- CARD 1 -->
                        <Border
            Grid.Column="0"
            BackgroundColor="#FFFFFF"
            Stroke="#E5E7EB"
            StrokeThickness="1"
            Padding="10"
            MinimumHeightRequest="150">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>

                            <Border.Shadow>
                                <Shadow Brush="#000000"
                        Opacity="0.05"
                        Offset="0,2"
                        Radius="6" />
                            </Border.Shadow>

                            <VerticalStackLayout
                Spacing="8"
                HorizontalOptions="Center"
                VerticalOptions="Center">

                                <Border
                    WidthRequest="58"
                    HeightRequest="58"
                    BackgroundColor="#F1F0FB"
                    StrokeThickness="0"
                    HorizontalOptions="Center">

                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="29" />
                                    </Border.StrokeShape>

                                    <Image
                        Source="balance.svg"
                        WidthRequest="34"
                        HeightRequest="34"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                                </Border>

                                <Label
                    Text="Punto justo"
                    FontSize="12"
                    FontAttributes="Bold"
                    TextColor="#0B2545"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="TailTruncation" />

                                <Label
                    Text="Equilibrado"
                    FontSize="10"
                    TextColor="#64748B"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="TailTruncation" />

                            </VerticalStackLayout>
                        </Border>

                        <!-- CARD 2 -->
                        <Border
            Grid.Column="1"
            BackgroundColor="#FFFFFF"
            Stroke="#E5E7EB"
            StrokeThickness="1"
            Padding="10"
            MinimumHeightRequest="150">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>

                            <Border.Shadow>
                                <Shadow Brush="#000000"
                        Opacity="0.05"
                        Offset="0,2"
                        Radius="6" />
                            </Border.Shadow>

                            <VerticalStackLayout
                Spacing="8"
                HorizontalOptions="Center"
                VerticalOptions="Center">

                                <Border
                    WidthRequest="58"
                    HeightRequest="58"
                    BackgroundColor="#EEF6FF"
                    StrokeThickness="0"
                    HorizontalOptions="Center">

                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="29" />
                                    </Border.StrokeShape>

                                    <Image
                        Source="route.svg"
                        WidthRequest="34"
                        HeightRequest="34"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                                </Border>

                                <Label
                    Text="Menos vueltas"
                    FontSize="12"
                    FontAttributes="Bold"
                    TextColor="#0B2545"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="TailTruncation" />

                                <Label
                    Text="Rutas directas"
                    FontSize="10"
                    TextColor="#64748B"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="TailTruncation" />

                            </VerticalStackLayout>
                        </Border>

                        <!-- CARD 3 -->
                        <Border
            Grid.Column="2"
            BackgroundColor="#FFFFFF"
            Stroke="#E5E7EB"
            StrokeThickness="1"
            Padding="10"
            MinimumHeightRequest="150">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>

                            <Border.Shadow>
                                <Shadow Brush="#000000"
                        Opacity="0.05"
                        Offset="0,2"
                        Radius="6" />
                            </Border.Shadow>

                            <VerticalStackLayout
                Spacing="8"
                HorizontalOptions="Center"
                VerticalOptions="Center">

                                <Border
                    WidthRequest="58"
                    HeightRequest="58"
                    BackgroundColor="#ECFDF5"
                    StrokeThickness="0"
                    HorizontalOptions="Center">

                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="29" />
                                    </Border.StrokeShape>

                                    <Image
                        Source="groups.png"
                        WidthRequest="34"
                        HeightRequest="34"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                                </Border>

                                <Label
                    Text="Grupo listo"
                    FontSize="12"
                    FontAttributes="Bold"
                    TextColor="#0B2545"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="TailTruncation" />

                                <Label
                    Text="Coordinados"
                    FontSize="10"
                    TextColor="#64748B"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="TailTruncation" />

                            </VerticalStackLayout>
                        </Border>

                    </Grid>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>