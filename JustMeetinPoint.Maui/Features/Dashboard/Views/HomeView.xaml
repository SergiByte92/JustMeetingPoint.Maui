<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="JustMeetinPoint.Maui.Features.Dashboard.Views.HomeView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:JustMeetinPoint.Maui.Features.Dashboard.ViewModels"
    x:DataType="vm:HomeViewModel"
    Title="Inicio"
    BackgroundColor="#F3F4F6">

    <ContentPage.Resources>

        <Style x:Key="M3ElevatedCard" TargetType="Border">
            <Setter Property="BackgroundColor" Value="#FFFFFF" />
            <Setter Property="Stroke" Value="#E5E7EB" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="StrokeShape">
                <Setter.Value>
                    <RoundRectangle CornerRadius="22" />
                </Setter.Value>
            </Setter>
            <Setter Property="Shadow">
                <Setter.Value>
                    <Shadow
                        Brush="#000000"
                        Opacity="0.05"
                        Offset="0,2"
                        Radius="6" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="M3OutlinedCard" TargetType="Border">
            <Setter Property="BackgroundColor" Value="#FFFFFF" />
            <Setter Property="Stroke" Value="#E5E7EB" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="StrokeShape">
                <Setter.Value>
                    <RoundRectangle CornerRadius="22" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="M3ValueCard" TargetType="Border">
            <Setter Property="BackgroundColor" Value="#FFFFFF" />
            <Setter Property="Stroke" Value="#E5E7EB" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="MinimumHeightRequest" Value="132" />
            <Setter Property="StrokeShape">
                <Setter.Value>
                    <RoundRectangle CornerRadius="18" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="M3PrimaryButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#1A73E8" />
            <Setter Property="TextColor" Value="#FFFFFF" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="HeightRequest" Value="48" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="M3SecondaryText" TargetType="Label">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextColor" Value="#5F6368" />
            <Setter Property="LineBreakMode" Value="WordWrap" />
        </Style>

    </ContentPage.Resources>

    <Grid RowDefinitions="*">

        <ScrollView>
            <VerticalStackLayout Padding="20,22,20,32" Spacing="18">

                <!-- SALUDO -->
                <VerticalStackLayout Spacing="4">
                    <Label
                        Text="{Binding GreetingText}"
                        FontSize="28"
                        FontAttributes="Bold"
                        TextColor="#0B57D0" />

                    <Label
                        Text="{Binding SubtitleText}"
                        Style="{StaticResource M3SecondaryText}" />
                </VerticalStackLayout>

                <!-- ERROR -->
                <Border
                    Style="{StaticResource M3OutlinedCard}"
                    IsVisible="{Binding HasError}"
                    BackgroundColor="#FFF7F7"
                    Stroke="#FAD2CF">

                    <Label
                        Text="{Binding ErrorMessage}"
                        FontSize="13"
                        TextColor="#D93025" />
                </Border>

                <!-- CTA PRINCIPAL -->
                <Border Style="{StaticResource M3ElevatedCard}">
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="14">

                        <VerticalStackLayout Grid.Row="0" Spacing="6">
                            <Label
                                Text="{Binding MainCtaTitle}"
                                FontSize="21"
                                FontAttributes="Bold"
                                TextColor="#202124" />

                            <Label
                                Text="{Binding MainCtaSubtitle}"
                                Style="{StaticResource M3SecondaryText}" />
                        </VerticalStackLayout>

                        <Button
                            Grid.Row="1"
                            Text="{Binding PrimaryButtonText}"
                            Style="{StaticResource M3PrimaryButton}"
                            Command="{Binding GoToActiveGroupCommand}" />

                        <ActivityIndicator
                            Grid.Row="2"
                            IsRunning="{Binding IsBusy}"
                            IsVisible="{Binding IsBusy}"
                            Color="#1A73E8"
                            HorizontalOptions="Center" />

                    </Grid>
                </Border>

                <!-- VALUE CARDS -->
                <VerticalStackLayout Spacing="12">

                    <Label
                        Text="Para una quedada perfecta"
                        FontSize="17"
                        FontAttributes="Bold"
                        TextColor="#0B57D0" />

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">

                        <!-- CARD 1 -->
                        <Border Grid.Column="0" Style="{StaticResource M3ValueCard}">
                            <VerticalStackLayout
                                Spacing="8"
                                HorizontalOptions="Center"
                                VerticalOptions="Center">

                                <Border
                                    WidthRequest="62"
                                    HeightRequest="62"
                                    BackgroundColor="#D2E3FC"
                                    StrokeThickness="0"
                                    HorizontalOptions="Center"
                                    StrokeShape="RoundRectangle 31">

                                    <Image
                                        Source="balance.svg"
                                        WidthRequest="38"
                                        HeightRequest="38"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center" />
                                </Border>

                                <Label
                                    Text="Punto justo"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    TextColor="#202124"
                                    HorizontalTextAlignment="Center"
                                    LineBreakMode="TailTruncation" />

                                <Label
                                    Text="Equilibrado"
                                    FontSize="11"
                                    TextColor="#5F6368"
                                    HorizontalTextAlignment="Center"
                                    LineBreakMode="TailTruncation" />

                            </VerticalStackLayout>
                        </Border>

                        <!-- CARD 2 -->
                        <Border Grid.Column="1" Style="{StaticResource M3ValueCard}">
                            <VerticalStackLayout
                                Spacing="8"
                                HorizontalOptions="Center"
                                VerticalOptions="Center">

                                <Border
                                    WidthRequest="62"
                                    HeightRequest="62"
                                    BackgroundColor="#D2E3FC"
                                    StrokeThickness="0"
                                    HorizontalOptions="Center"
                                    StrokeShape="RoundRectangle 31">

                                    <Image
                                        Source="route.svg"
                                        WidthRequest="38"
                                        HeightRequest="38"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center" />
                                </Border>

                                <Label
                                    Text="Menos vueltas"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    TextColor="#202124"
                                    HorizontalTextAlignment="Center"
                                    LineBreakMode="TailTruncation" />

                                <Label
                                    Text="Rutas directas"
                                    FontSize="11"
                                    TextColor="#5F6368"
                                    HorizontalTextAlignment="Center"
                                    LineBreakMode="TailTruncation" />

                            </VerticalStackLayout>
                        </Border>

                        <!-- CARD 3 -->
                        <Border Grid.Column="2" Style="{StaticResource M3ValueCard}">
                            <VerticalStackLayout
                                Spacing="8"
                                HorizontalOptions="Center"
                                VerticalOptions="Center">

                                <Border
                                    WidthRequest="62"
                                    HeightRequest="62"
                                    BackgroundColor="#D2E3FC"
                                    StrokeThickness="0"
                                    HorizontalOptions="Center"
                                    StrokeShape="RoundRectangle 31">

                                    <Image
                                        Source="groups.svg"
                                        WidthRequest="38"
                                        HeightRequest="38"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center" />
                                </Border>

                                <Label
                                    Text="Grupo listo"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    TextColor="#202124"
                                    HorizontalTextAlignment="Center"
                                    LineBreakMode="TailTruncation" />

                                <Label
                                    Text="Coordinados"
                                    FontSize="11"
                                    TextColor="#5F6368"
                                    HorizontalTextAlignment="Center"
                                    LineBreakMode="TailTruncation" />

                            </VerticalStackLayout>
                        </Border>

                    </Grid>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>