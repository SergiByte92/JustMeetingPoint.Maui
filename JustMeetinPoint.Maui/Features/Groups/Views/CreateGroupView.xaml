<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="JustMeetinPoint.Maui.Features.Groups.Views.CreateGroupView"
    Title="Crear grupo"
    BackgroundColor="#F3F4F6"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,28,20,32" Spacing="22">

                <!-- HEADER -->
                <VerticalStackLayout Spacing="4">
                    <Label
                        Text="Configura tu quedada"
                        FontSize="28"
                        FontAttributes="Bold"
                        TextColor="#0B57D0" />

                    <Label
                        Text="Define los datos básicos antes de crear el grupo."
                        FontSize="14"
                        TextColor="#5F6368" />
                </VerticalStackLayout>

                <!-- NOMBRE -->
                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="Nombre"
                        FontSize="13"
                        FontAttributes="Bold"
                        TextColor="#202124" />

                    <Border
                        BackgroundColor="#FFFFFF"
                        Stroke="#D2E3FC"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        Padding="14,4">

                        <Entry
                            Text="{Binding Name}"
                            Placeholder="Ej. Cena de equipo"
                            PlaceholderColor="#5F6368"
                            TextColor="#202124"
                            BackgroundColor="Transparent"
                            HeightRequest="48"
                            MaxLength="50" />
                    </Border>
                </VerticalStackLayout>

                <!-- DESCRIPCIÓN -->
                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="Descripción"
                        FontSize="13"
                        FontAttributes="Bold"
                        TextColor="#202124" />

                    <Border
                        BackgroundColor="#FFFFFF"
                        Stroke="#D2E3FC"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 18"
                        Padding="14,10">

                        <Editor
                            Text="{Binding Description}"
                            Placeholder="Añade contexto si lo necesitas"
                            PlaceholderColor="#5F6368"
                            TextColor="#202124"
                            BackgroundColor="Transparent"
                            HeightRequest="96"
                            MaxLength="250"
                            AutoSize="TextChanges" />
                    </Border>
                </VerticalStackLayout>

                <!-- MOTIVO -->
                <VerticalStackLayout Spacing="10">
                    <Label
                        Text="Motivo"
                        FontSize="13"
                        FontAttributes="Bold"
                        TextColor="#202124" />

                    <FlexLayout
                        BindableLayout.ItemsSource="{Binding Categories}"
                        Wrap="Wrap"
                        Direction="Row"
                        JustifyContent="Start"
                        AlignItems="Start">

                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Margin="0,0,8,8"
                                    Padding="16,10"
                                    BackgroundColor="#FFFFFF"
                                    Stroke="#E5E7EB"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 22"
                                    MinimumHeightRequest="44">

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectCategoryCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Label
                                        Text="{Binding Name}"
                                        FontSize="12"
                                        TextColor="#202124"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center" />

                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BackgroundColor" Value="#D2E3FC" />
                                            <Setter Property="Stroke" Value="#1A73E8" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                </VerticalStackLayout>

                <!-- MÉTODO -->
                <VerticalStackLayout Spacing="10">
                    <Label
                        Text="Método"
                        FontSize="13"
                        FontAttributes="Bold"
                        TextColor="#202124" />

                    <VerticalStackLayout
                        BindableLayout.ItemsSource="{Binding Methods}"
                        Spacing="10">

                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    BackgroundColor="#FFFFFF"
                                    Stroke="#E5E7EB"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="16,14"
                                    MinimumHeightRequest="64"
                                    Opacity="1">

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectMethodCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <VerticalStackLayout Spacing="4">
                                        <Label
                                            Text="{Binding Name}"
                                            FontSize="14"
                                            FontAttributes="Bold"
                                            TextColor="#202124" />

                                        <Label
                                            Text="{Binding Description}"
                                            FontSize="12"
                                            TextColor="#5F6368" />
                                    </VerticalStackLayout>

                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BackgroundColor" Value="#D2E3FC" />
                                            <Setter Property="Stroke" Value="#1A73E8" />
                                        </DataTrigger>

                                        <DataTrigger TargetType="Border" Binding="{Binding IsEnabled}" Value="False">
                                            <Setter Property="Opacity" Value="0.55" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- CTA + ERROR FIJO -->
        <Border
            Grid.Row="1"
            BackgroundColor="#F3F4F6"
            StrokeThickness="0"
            Padding="20,12,20,20">

            <VerticalStackLayout Spacing="10">

                <Border
                    IsVisible="{Binding HasError}"
                    BackgroundColor="#FEE2E2"
                    Stroke="#FCA5A5"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    Padding="12">

                    <Label
                        Text="{Binding ErrorMessage}"
                        TextColor="#991B1B"
                        FontSize="13"
                        FontAttributes="Bold" />
                </Border>

                <Button
                    Text="Crear grupo"
                    Command="{Binding CreateGroupCommand}"
                    IsEnabled="{Binding IsNotBusy}"
                    HeightRequest="52"
                    CornerRadius="16"
                    BackgroundColor="#1A73E8"
                    TextColor="#FFFFFF"
                    FontAttributes="Bold" />

            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>