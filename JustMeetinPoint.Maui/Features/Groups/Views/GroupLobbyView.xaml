<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="JustMeetinPoint.Maui.Features.Groups.Views.GroupLobbyView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Lobby"
    BackgroundColor="#F7F8FA"
    Shell.NavBarIsVisible="True">

    <ScrollView>
        <VerticalStackLayout
            Padding="24,20,24,32"
            Spacing="18">

            <!-- Stepper superior -->
            <Grid
                ColumnDefinitions="*,Auto,*,Auto,*"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Margin="0,6,0,8">

                <BoxView Grid.Column="0"
                         HeightRequest="4"
                         WidthRequest="36"
                         CornerRadius="2"
                         Color="{Binding Step1Color}"
                         VerticalOptions="Center" />

                <Ellipse Grid.Column="1"
                         WidthRequest="12"
                         HeightRequest="12"
                         Fill="{Binding Step1Color}"
                         VerticalOptions="Center"
                         HorizontalOptions="Center" />

                <BoxView Grid.Column="2"
                         HeightRequest="4"
                         WidthRequest="36"
                         CornerRadius="2"
                         Color="{Binding Step2Color}"
                         VerticalOptions="Center" />

                <Ellipse Grid.Column="3"
                         WidthRequest="12"
                         HeightRequest="12"
                         Fill="{Binding Step2Color}"
                         VerticalOptions="Center"
                         HorizontalOptions="Center" />

                <BoxView Grid.Column="4"
                         HeightRequest="4"
                         WidthRequest="36"
                         CornerRadius="2"
                         Color="{Binding Step3Color}"
                         VerticalOptions="Center" />
            </Grid>

            <!-- Título -->
            <VerticalStackLayout Spacing="4">
                <Label
                    Text="{Binding LobbyTitle}"
                    FontSize="34"
                    FontAttributes="Bold"
                    TextColor="#1F1F1F" />

                <Label
                    Text="{Binding RoleText}"
                    FontSize="14"
                    TextColor="#6B7280" />
            </VerticalStackLayout>

            <!-- Código -->
            <Frame
                Padding="18"
                CornerRadius="18"
                BackgroundColor="White"
                BorderColor="#E6EAF0"
                HasShadow="False">

                <VerticalStackLayout Spacing="10">
                    <Label
                        Text="Código del grupo"
                        FontSize="14"
                        FontAttributes="Bold"
                        TextColor="#374151" />

                    <Label
                        Text="{Binding GroupCode}"
                        FontSize="24"
                        FontAttributes="Bold"
                        TextColor="#234A84"
                        HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Frame>

            <!-- Resumen rápido -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Frame
                    Grid.Column="0"
                    Padding="16"
                    CornerRadius="18"
                    BackgroundColor="White"
                    BorderColor="#E6EAF0"
                    HasShadow="False">

                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Participantes"
                            FontSize="13"
                            TextColor="#6B7280" />

                        <Label
                            Text="{Binding ParticipantsText}"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="#1F1F1F" />
                    </VerticalStackLayout>
                </Frame>

                <Frame
                    Grid.Column="1"
                    Padding="16"
                    CornerRadius="18"
                    BackgroundColor="White"
                    BorderColor="#E6EAF0"
                    HasShadow="False">

                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Rol"
                            FontSize="13"
                            TextColor="#6B7280" />

                        <Label
                            Text="{Binding RoleText}"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="#1F1F1F" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- Estado principal -->
            <Frame
                Padding="18"
                CornerRadius="20"
                BackgroundColor="White"
                BorderColor="#E6EAF0"
                HasShadow="False">

                <VerticalStackLayout Spacing="14">

                    <VerticalStackLayout Spacing="4">
                        <Label
                            Text="Estado"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="#374151" />

                        <Label
                            Text="{Binding CurrentStatus}"
                            FontSize="22"
                            FontAttributes="Bold"
                            TextColor="#1F1F1F" />

                        <Label
                            Text="{Binding CurrentSubStatus}"
                            FontSize="14"
                            TextColor="#6B7280" />
                    </VerticalStackLayout>

                    <ProgressBar
                        Progress="{Binding ProgressValue}"
                        HeightRequest="8"
                        BackgroundColor="#E5E7EB"
                        ProgressColor="#2F67C7" />

                    <ActivityIndicator
                        IsVisible="{Binding IsCalculating}"
                        IsRunning="{Binding IsCalculating}"
                        Color="#2F67C7"
                        HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

            <!-- Error -->
            <Frame
                Padding="16"
                CornerRadius="16"
                BackgroundColor="#FFF5F5"
                BorderColor="#F5C2C7"
                HasShadow="False"
                IsVisible="{Binding HasError}">

                <VerticalStackLayout Spacing="6">
                    <Label
                        Text="Se ha producido un error"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="#B42318" />

                    <Label
                        Text="{Binding ErrorMessage}"
                        FontSize="14"
                        TextColor="#7A271A" />
                </VerticalStackLayout>
            </Frame>

            <!-- Botones -->
            <Button
                Text="Iniciar grupo"
                Command="{Binding StartCommand}"
                IsVisible="{Binding CanStartGroup}"
                BackgroundColor="#2F67C7"
                TextColor="White"
                FontAttributes="Bold"
                CornerRadius="16"
                HeightRequest="56" />

            <Button
                Text="Salir del grupo"
                Command="{Binding LeaveGroupCommand}"
                BackgroundColor="White"
                TextColor="#D84B4B"
                BorderColor="#F2B6B6"
                BorderWidth="1.2"
                CornerRadius="16"
                HeightRequest="56" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>