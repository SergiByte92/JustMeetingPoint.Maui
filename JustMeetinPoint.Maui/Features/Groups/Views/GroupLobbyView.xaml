<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="JustMeetinPoint.Maui.Features.Groups.Views.GroupLobbyView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Lobby"
    BackgroundColor="#F3F4F6"
    Shell.NavBarIsVisible="True">

    <ScrollView>
        <VerticalStackLayout Padding="20,22,20,32" Spacing="18">

            <Grid
                ColumnDefinitions="*,Auto,*,Auto,*"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Margin="0,4,0,6">

                <BoxView
                    Grid.Column="0"
                    HeightRequest="4"
                    WidthRequest="36"
                    CornerRadius="2"
                    Color="{Binding Step1Color}"
                    VerticalOptions="Center" />

                <Ellipse
                    Grid.Column="1"
                    WidthRequest="12"
                    HeightRequest="12"
                    Fill="{Binding Step1Color}" />

                <BoxView
                    Grid.Column="2"
                    HeightRequest="4"
                    WidthRequest="36"
                    CornerRadius="2"
                    Color="{Binding Step2Color}"
                    VerticalOptions="Center" />

                <Ellipse
                    Grid.Column="3"
                    WidthRequest="12"
                    HeightRequest="12"
                    Fill="{Binding Step2Color}" />

                <BoxView
                    Grid.Column="4"
                    HeightRequest="4"
                    WidthRequest="36"
                    CornerRadius="2"
                    Color="{Binding Step3Color}"
                    VerticalOptions="Center" />
            </Grid>

            <VerticalStackLayout Spacing="4">
                <Label
                    Text="{Binding LobbyTitle}"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="#0B57D0" />

                <Label
                    Text="{Binding RoleText}"
                    FontSize="14"
                    TextColor="#5F6368" />
            </VerticalStackLayout>

            <Border
                Padding="18"
                BackgroundColor="#FFFFFF"
                Stroke="#E5E7EB"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24">

                <VerticalStackLayout Spacing="10">
                    <Label
                        Text="Código del grupo"
                        FontSize="14"
                        FontAttributes="Bold"
                        TextColor="#202124" />

                    <Border
                        BackgroundColor="#D2E3FC"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        Padding="14">

                        <Label
                            Text="{Binding GroupCode}"
                            FontSize="24"
                            FontAttributes="Bold"
                            TextColor="#1A73E8"
                            HorizontalTextAlignment="Center" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                <Border
                    Grid.Column="0"
                    Padding="16"
                    BackgroundColor="#FFFFFF"
                    Stroke="#E5E7EB"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 22">

                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Participantes"
                            FontSize="13"
                            TextColor="#5F6368" />

                        <Label
                            Text="{Binding ParticipantsText}"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="#202124" />
                    </VerticalStackLayout>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="16"
                    BackgroundColor="#FFFFFF"
                    Stroke="#E5E7EB"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 22">

                    <VerticalStackLayout Spacing="6">
                        <Label
                            Text="Rol"
                            FontSize="13"
                            TextColor="#5F6368" />

                        <Label
                            Text="{Binding RoleText}"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="#202124" />
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <Border
                Padding="18"
                BackgroundColor="#FFFFFF"
                Stroke="#E5E7EB"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24">

                <VerticalStackLayout Spacing="14">

                    <VerticalStackLayout Spacing="4">
                        <Label
                            Text="Estado"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="#202124" />

                        <Label
                            Text="{Binding CurrentStatus}"
                            FontSize="22"
                            FontAttributes="Bold"
                            TextColor="#202124" />

                        <Label
                            Text="{Binding CurrentSubStatus}"
                            FontSize="14"
                            TextColor="#5F6368" />
                    </VerticalStackLayout>

                    <ProgressBar
                        Progress="{Binding ProgressValue}"
                        HeightRequest="8"
                        BackgroundColor="#D2E3FC"
                        ProgressColor="#1A73E8" />

                    <!--
                        Se elimina ActivityIndicator.
                        Ya existe feedback suficiente con:
                        - CurrentStatus
                        - CurrentSubStatus
                        - ProgressBar

                        Esto reduce ruido visual y evita que el usuario perciba
                        un spinner infinito cuando el sistema está esperando OTP/polling.
                    -->

                </VerticalStackLayout>
            </Border>

            <Border
                Padding="16"
                BackgroundColor="#FFF7F7"
                Stroke="#FAD2CF"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 22"
                IsVisible="{Binding HasError}">

                <VerticalStackLayout Spacing="6">
                    <Label
                        Text="Se ha producido un error"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="#D93025" />

                    <Label
                        Text="{Binding ErrorMessage}"
                        FontSize="14"
                        TextColor="#7A271A" />
                </VerticalStackLayout>
            </Border>

            <Button
                Text="Iniciar grupo"
                Command="{Binding StartCommand}"
                IsVisible="{Binding CanStartGroup}"
                BackgroundColor="#1A73E8"
                TextColor="#FFFFFF"
                FontAttributes="Bold"
                CornerRadius="16"
                HeightRequest="52" />

            <Button
                Text="Salir del grupo"
                Command="{Binding LeaveGroupCommand}"
                BackgroundColor="#FFFFFF"
                TextColor="#D93025"
                BorderColor="#FAD2CF"
                BorderWidth="1"
                FontAttributes="Bold"
                CornerRadius="16"
                HeightRequest="52" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>