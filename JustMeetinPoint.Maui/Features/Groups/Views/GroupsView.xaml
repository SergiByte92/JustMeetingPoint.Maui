<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="JustMeetinPoint.Maui.Features.Groups.Views.GroupsView"
    Title="Quedadas"
    BackgroundColor="#F3F4F6">

    <ScrollView>
        <VerticalStackLayout Padding="20,22,20,32" Spacing="18">

            <!-- HEADER -->
            <VerticalStackLayout Spacing="4">
                <Label
                    Text="Organiza tu quedada"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="#0B57D0" />

                <Label
                    Text="Crea un grupo o accede con un código."
                    FontSize="14"
                    TextColor="#5F6368" />
            </VerticalStackLayout>

            <!-- CTA CREAR GRUPO -->
            <Border
                BackgroundColor="#FFFFFF"
                Stroke="#E5E7EB"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24"
                Padding="18">

                <VerticalStackLayout Spacing="14">

                    <VerticalStackLayout Spacing="4">
                        <Label
                            Text="Crear grupo"
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="#202124" />

                        <Label
                            Text="Genera un código para invitar a otros usuarios."
                            FontSize="14"
                            TextColor="#5F6368" />
                    </VerticalStackLayout>

                    <Button
                        Text="Crear grupo"
                        HeightRequest="48"
                        CornerRadius="16"
                        BackgroundColor="#1A73E8"
                        TextColor="#FFFFFF"
                        FontAttributes="Bold"
                        Command="{Binding CreateGroupCommand}" />

                </VerticalStackLayout>
            </Border>

            <!-- SEPARADOR -->
            <Grid ColumnDefinitions="*,Auto,*" VerticalOptions="Center">
                <BoxView
                    HeightRequest="1"
                    Color="#E5E7EB"
                    VerticalOptions="Center" />

                <Label
                    Grid.Column="1"
                    Text="o unirse con código"
                    FontSize="12"
                    TextColor="#5F6368"
                    Margin="10,0" />

                <BoxView
                    Grid.Column="2"
                    HeightRequest="1"
                    Color="#E5E7EB"
                    VerticalOptions="Center" />
            </Grid>

            <!-- JOIN CARD -->
            <Border
                BackgroundColor="#FFFFFF"
                Stroke="#E5E7EB"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24"
                Padding="18">

                <VerticalStackLayout Spacing="14">

                    <VerticalStackLayout Spacing="4">
                        <Label
                            Text="Unirse a un grupo"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="#202124" />

                        <Label
                            Text="Introduce el código compartido por el creador."
                            FontSize="13"
                            TextColor="#5F6368" />
                    </VerticalStackLayout>

                    <Border
                        BackgroundColor="#FFFFFF"
                        Stroke="#D2E3FC"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="14,4">

                        <Entry
                            Text="{Binding JoinCode}"
                            Placeholder="CÓDIGO"
                            PlaceholderColor="#5F6368"
                            TextColor="#202124"
                            BackgroundColor="Transparent"
                            HeightRequest="48"
                            MaxLength="12"
                            TextTransform="Uppercase"
                            HorizontalTextAlignment="Center"
                            FontAttributes="Bold" />
                    </Border>

                    <Button
                        Text="Unirme"
                        HeightRequest="48"
                        CornerRadius="16"
                        BackgroundColor="#D2E3FC"
                        TextColor="#1A73E8"
                        FontAttributes="Bold"
                        Command="{Binding JoinGroupCommand}" />

                </VerticalStackLayout>
            </Border>

            <!-- ERROR -->
            <Label
                Text="{Binding ErrorMessage}"
                TextColor="#D93025"
                FontSize="13"
                HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>