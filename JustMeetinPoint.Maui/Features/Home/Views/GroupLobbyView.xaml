<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="JustMeetinPoint.Maui.Features.Home.Views.GroupLobbyView"
    BackgroundColor="#0B2545"
    Shell.TabBarIsVisible="False"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="24,28,24,32" Spacing="24">

            <Label
                Text="Comparte este código con tu grupo."
                FontSize="15"
                TextColor="#BDBDBD" />

            <Border
                BackgroundColor="#081C34"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 18"
                Padding="20">

                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="Código del grupo"
                        FontSize="14"
                        TextColor="#BDBDBD" />

                    <Label
                        Text="{Binding GroupCode}"
                        FontSize="32"
                        FontAttributes="Bold"
                        TextColor="#EAEAEA" />
                </VerticalStackLayout>
            </Border>

            <Border
                BackgroundColor="#081C34"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 18"
                Padding="18">

                <VerticalStackLayout Spacing="10">
                    <Label
                        Text="Estado del grupo"
                        FontSize="14"
                        TextColor="#BDBDBD" />

                    <Label
                        Text="{Binding ParticipantsText}"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="#EAEAEA" />

                    <Label
                        Text="{Binding StatusText}"
                        FontSize="14"
                        TextColor="#BDBDBD" />
                </VerticalStackLayout>
            </Border>

            <Button
                Text="Actualizar"
                HeightRequest="52"
                CornerRadius="14"
                BackgroundColor="#102A49"
                TextColor="#EAEAEA"
                Command="{Binding RefreshCommand}" />

            <Button
                Text="Iniciar grupo"
                IsVisible="{Binding CanStartGroup}"
                Command="{Binding StartCommand}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>