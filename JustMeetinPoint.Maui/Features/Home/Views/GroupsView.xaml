<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="JustMeetinPoint.Maui.Features.Home.Views.GroupsView"
    Title="Quedadas"
    BackgroundColor="#F6F7F9">

    <ScrollView>
        <VerticalStackLayout Padding="16,16,16,28" Spacing="20">

            <!-- HEADER -->
            <VerticalStackLayout Spacing="4">
                <Label
                    Text="Organiza tu quedada"
                    FontSize="26"
                    FontAttributes="Bold"
                    TextColor="#20242A" />

                <Label
                    Text="Crea un grupo o accede con un código."
                    FontSize="14"
                    TextColor="#667085" />
            </VerticalStackLayout>

            <!-- CTA PRINCIPAL -->
            <Border
                BackgroundColor="#1F5FBF"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16"
                Padding="18">

                <VerticalStackLayout Spacing="10">

                    <Label
                        Text="Crear grupo"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="#FFFFFF" />

                    <Button
                        Text="Crear grupo"
                        HeightRequest="48"
                        CornerRadius="12"
                        BackgroundColor="#FFFFFF"
                        TextColor="#163E73"
                        FontAttributes="Bold"
                        Command="{Binding CreateGroupCommand}" />
                </VerticalStackLayout>
            </Border>

            <!-- SEPARADOR -->
            <Grid ColumnDefinitions="*,Auto,*" VerticalOptions="Center">
                <BoxView HeightRequest="1" Color="#E5E7EB" VerticalOptions="Center"/>
                <Label
                    Grid.Column="1"
                    Text="o unirse con código"
                    FontSize="12"
                    TextColor="#98A2B3"
                    Margin="8,0" />
                <BoxView Grid.Column="2" HeightRequest="1" Color="#E5E7EB" VerticalOptions="Center"/>
            </Grid>

            <!-- FORM JOIN -->
            <VerticalStackLayout Spacing="10">

                <Entry
                    Text="{Binding JoinCode}"
                    Placeholder="Introduce código"
                    PlaceholderColor="#98A2B3"
                    TextColor="#20242A"
                    BackgroundColor="#FFFFFF"
                    HeightRequest="50"
                    MaxLength="12"
                    TextTransform="Uppercase"
                    HorizontalTextAlignment="Center"
                    FontAttributes="Bold" />

                <Button
                    Text="Unirme"
                    HeightRequest="48"
                    CornerRadius="12"
                    BackgroundColor="#EEF2F6"
                    TextColor="#163E73"
                    FontAttributes="Bold"
                    Command="{Binding JoinGroupCommand}" />

            </VerticalStackLayout>

            <!-- ERROR -->
            <Label
                Text="{Binding ErrorMessage}"
                TextColor="#D92D20"
                FontSize="13"
                HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>