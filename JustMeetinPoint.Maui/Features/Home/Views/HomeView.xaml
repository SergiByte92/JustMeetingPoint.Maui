<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="JustMeetinPoint.Maui.Features.Home.Views.HomeView"
    Title="Inicio"
    BackgroundColor="#F6F7F9">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- HERO SUPERIOR -->
            <Border
                BackgroundColor="#FFFFFF"
                Stroke="#D9DEE5"
                StrokeThickness="1"
                Padding="20,18,20,18">

                <VerticalStackLayout Spacing="4">
                    <Label
                        Text="Hola, Sergi"
                        FontSize="24"
                        FontAttributes="Bold"
                        TextColor="#20242A" />

                    <Label
                        Text="¿Dónde quedamos hoy?"
                        FontSize="14"
                        TextColor="#667085" />
                </VerticalStackLayout>
            </Border>

            <!-- CTA PRINCIPAL -->
            <Border
                Margin="12,12,12,0"
                BackgroundColor="#1F5FBF"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16"
                Padding="18">

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">

                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="Organiza una nueva quedada"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="#FFFFFF" />

                        <Label
                            Text="Crea un grupo, comparte el código y encuentra el punto de encuentro más equilibrado."
                            FontSize="12"
                            TextColor="#DCE6F5"
                            LineBreakMode="WordWrap" />

                        <Button
                            Text="Crear grupo"
                            Margin="0,10,0,0"
                            WidthRequest="140"
                            HeightRequest="42"
                            BackgroundColor="#FFFFFF"
                            TextColor="#163E73"
                            FontAttributes="Bold"
                            CornerRadius="12"
                            HorizontalOptions="Start" />
                    </VerticalStackLayout>

                    <!-- Acento decorativo sobrio -->
                    <Border
                        Grid.Column="1"
                        WidthRequest="10"
                        HeightRequest="10"
                        BackgroundColor="#9BB7E3"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 5"
                        VerticalOptions="Center"
                        HorizontalOptions="End"
                        Opacity="0.85" />
                </Grid>
            </Border>

            <!-- HEADER SECCIÓN -->
            <Grid
                Padding="16,18,16,8"
                ColumnDefinitions="*,Auto">

                <Label
                    Text="Sugerencias para hoy"
                    FontSize="15"
                    FontAttributes="Bold"
                    TextColor="#20242A" />

                <Label
                    Grid.Column="1"
                    Text="Ver más"
                    FontSize="12"
                    TextColor="#1F5FBF"
                    VerticalOptions="End" />
            </Grid>

            <!-- CHIPS SOBRIOS -->
            <ScrollView
                Orientation="Horizontal"
                Margin="12,0,0,0"
                HorizontalScrollBarVisibility="Never">

                <HorizontalStackLayout Spacing="8" Padding="0,0,12,0">

                    <Border
                        BackgroundColor="#EAF1FB"
                        Stroke="#1F5FBF"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        Padding="14,8">
                        <Label
                            Text="Comer"
                            FontSize="12"
                            FontAttributes="Bold"
                            TextColor="#1F5FBF" />
                    </Border>

                    <Border
                        BackgroundColor="#FFFFFF"
                        Stroke="#D9DEE5"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        Padding="14,8">
                        <Label
                            Text="Café"
                            FontSize="12"
                            TextColor="#20242A" />
                    </Border>

                    <Border
                        BackgroundColor="#FFFFFF"
                        Stroke="#D9DEE5"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        Padding="14,8">
                        <Label
                            Text="Ocio"
                            FontSize="12"
                            TextColor="#20242A" />
                    </Border>

                    <Border
                        BackgroundColor="#FFFFFF"
                        Stroke="#D9DEE5"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 20"
                        Padding="14,8">
                        <Label
                            Text="Deporte"
                            FontSize="12"
                            TextColor="#20242A" />
                    </Border>

                </HorizontalStackLayout>
            </ScrollView>

            <!-- CARD 1 -->
            <Border
                Margin="12,12,12,0"
                BackgroundColor="#FFFFFF"
                Stroke="#D9DEE5"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 14"
                Padding="14">

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Border
                        WidthRequest="40"
                        HeightRequest="40"
                        BackgroundColor="#EEF2F6"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12">
                        <BoxView
                            WidthRequest="14"
                            HeightRequest="14"
                            CornerRadius="7"
                            Color="#1F5FBF"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <Label
                            Text="Actividades para grupos pequeños"
                            FontSize="13"
                            FontAttributes="Bold"
                            TextColor="#20242A" />

                        <Label
                            Text="Propuestas rápidas para reuniones de baja fricción."
                            FontSize="11"
                            TextColor="#667085" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- CARD 2 -->
            <Border
                Margin="12,8,12,20"
                BackgroundColor="#FFFFFF"
                Stroke="#D9DEE5"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 14"
                Padding="14">

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Border
                        WidthRequest="40"
                        HeightRequest="40"
                        BackgroundColor="#EEF2F6"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12">
                        <BoxView
                            WidthRequest="14"
                            HeightRequest="14"
                            CornerRadius="7"
                            Color="#667085"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <Label
                            Text="Sugerencia de punto final"
                            FontSize="13"
                            FontAttributes="Bold"
                            TextColor="#20242A" />

                        <Label
                            Text="Aquí podrás mostrar locales o puntos de interés cercanos al resultado."
                            FontSize="11"
                            TextColor="#667085" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>