<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="JustMeetinPoint.Maui.Features.Home.Views.MapView"
    Title="Mapa"
    BackgroundColor="#0B2545">

    <VerticalStackLayout Padding="24" Spacing="16">
        <Label Text="Resultado del servidor"
               FontSize="24"
               FontAttributes="Bold"
               TextColor="White" />

        <Label Text="{Binding Latitude, StringFormat='Latitud: {0:F6}'}"
               TextColor="White"
               FontSize="16" />

        <Label Text="{Binding Longitude, StringFormat='Longitud: {0:F6}'}"
               TextColor="White"
               FontSize="16" />

        <Label Text="{Binding DurationSeconds, StringFormat='Duración: {0} segundos'}"
               TextColor="White"
               FontSize="16" />
    </VerticalStackLayout>
</ContentPage>