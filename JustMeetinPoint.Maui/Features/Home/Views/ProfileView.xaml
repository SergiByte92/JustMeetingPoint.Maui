<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="JustMeetinPoint.Maui.Features.Home.Views.ProfileView"
    Title="Perfil"
    BackgroundColor="#F6F7F9">

    <ScrollView>
        <VerticalStackLayout Spacing="12" Padding="12,12,12,24">

            <!-- HEADER PERFIL -->
            <Border
                BackgroundColor="#FFFFFF"
                Stroke="#D9DEE5"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                Padding="16">

                <VerticalStackLayout Spacing="14">

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                        <Border
                            WidthRequest="58"
                            HeightRequest="58"
                            BackgroundColor="#1F5FBF"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 29">

                            <Label
                                Text="{Binding UserInitials}"
                                FontSize="22"
                                FontAttributes="Bold"
                                TextColor="White"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label
                                Text="{Binding FullName}"
                                FontSize="17"
                                FontAttributes="Bold"
                                TextColor="#20242A" />

                            <Label
                                Text="{Binding Email}"
                                FontSize="12"
                                TextColor="#667085" />
                        </VerticalStackLayout>
                    </Grid>

                    <Border
                        BackgroundColor="#F8F9FB"
                        Stroke="#D9DEE5"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        Padding="14,12">

                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <BoxView
                                WidthRequest="12"
                                HeightRequest="12"
                                CornerRadius="6"
                                Color="#1F5FBF"
                                VerticalOptions="Center" />

                            <Label
                                Grid.Column="1"
                                Text="Datos personales"
                                FontSize="13"
                                FontAttributes="Bold"
                                TextColor="#20242A"
                                VerticalOptions="Center" />

                            <Label
                                Grid.Column="2"
                                Text="›"
                                FontSize="16"
                                TextColor="#98A2B3"
                                VerticalOptions="Center" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>
            </Border>

            <!-- ESTADÍSTICAS -->
            <Border
                BackgroundColor="#FFFFFF"
                Stroke="#D9DEE5"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                Padding="16">

                <VerticalStackLayout Spacing="14">

                    <VerticalStackLayout Spacing="4">
                        <Label
                            Text="Estadísticas del usuario"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="#20242A" />

                        <Label
                            Text="Resumen visual de tu actividad dentro de JMP."
                            FontSize="12"
                            TextColor="#667085" />
                    </VerticalStackLayout>

                    <!-- PLACEHOLDER DE GRÁFICO MÁS SOBRIO -->
                    <Border
                        BackgroundColor="#F8F9FB"
                        Stroke="#D9DEE5"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 14"
                        Padding="12"
                        HeightRequest="220">

                        <Grid HeightRequest="190">

                            <Border
                                BackgroundColor="#2F6FC2"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 10"
                                HeightRequest="110"
                                WidthRequest="26"
                                HorizontalOptions="Start"
                                VerticalOptions="End"
                                Margin="12,0,0,0" />

                            <Border
                                BackgroundColor="#4F7FBF"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 10"
                                HeightRequest="150"
                                WidthRequest="26"
                                HorizontalOptions="Start"
                                VerticalOptions="End"
                                Margin="54,0,0,0" />

                            <Border
                                BackgroundColor="#7E9BC2"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 10"
                                HeightRequest="82"
                                WidthRequest="26"
                                HorizontalOptions="Start"
                                VerticalOptions="End"
                                Margin="96,0,0,0" />

                            <Border
                                BackgroundColor="#163E73"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 10"
                                HeightRequest="168"
                                WidthRequest="26"
                                HorizontalOptions="Start"
                                VerticalOptions="End"
                                Margin="138,0,0,0" />

                            <Label
                                Text="Actividad mensual"
                                FontSize="12"
                                TextColor="#667085"
                                HorizontalOptions="End"
                                VerticalOptions="Start"
                                Margin="0,6,6,0" />
                        </Grid>
                    </Border>

                    <!-- KPIs -->
                    <Grid
                        ColumnDefinitions="*,*"
                        RowDefinitions="Auto,Auto"
                        ColumnSpacing="10"
                        RowSpacing="10">

                        <Border
                            Grid.Row="0"
                            Grid.Column="0"
                            BackgroundColor="#F8F9FB"
                            Stroke="#D9DEE5"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12"
                            Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label
                                    Text="Quedadas creadas"
                                    FontSize="11"
                                    TextColor="#667085" />
                                <Label
                                    Text="{Binding MeetingsCreated}"
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    TextColor="#20242A" />
                            </VerticalStackLayout>
                        </Border>

                        <Border
                            Grid.Row="0"
                            Grid.Column="1"
                            BackgroundColor="#F8F9FB"
                            Stroke="#D9DEE5"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12"
                            Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label
                                    Text="Grupos completados"
                                    FontSize="11"
                                    TextColor="#667085" />
                                <Label
                                    Text="{Binding CompletedGroups}"
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    TextColor="#20242A" />
                            </VerticalStackLayout>
                        </Border>

                        <Border
                            Grid.Row="1"
                            Grid.Column="0"
                            BackgroundColor="#F8F9FB"
                            Stroke="#D9DEE5"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12"
                            Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label
                                    Text="Tiempo medio"
                                    FontSize="11"
                                    TextColor="#667085" />
                                <Label
                                    Text="{Binding AvgTravelTimeText}"
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    TextColor="#20242A" />
                            </VerticalStackLayout>
                        </Border>

                        <Border
                            Grid.Row="1"
                            Grid.Column="1"
                            BackgroundColor="#F8F9FB"
                            Stroke="#D9DEE5"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 12"
                            Padding="12">
                            <VerticalStackLayout Spacing="4">
                                <Label
                                    Text="Última actividad"
                                    FontSize="11"
                                    TextColor="#667085" />
                                <Label
                                    Text="{Binding LastActivityText}"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    TextColor="#20242A" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- AJUSTES -->
            <Border
                BackgroundColor="#FFFFFF"
                Stroke="#D9DEE5"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                Padding="0">

                <VerticalStackLayout Spacing="0">

                    <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <BoxView WidthRequest="12" HeightRequest="12" CornerRadius="6" Color="#667085" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Notificaciones" FontSize="13" TextColor="#20242A" VerticalOptions="Center" />
                        <Label Grid.Column="2" Text="›" FontSize="16" TextColor="#98A2B3" VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#EEF1F4" />

                    <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <BoxView WidthRequest="12" HeightRequest="12" CornerRadius="6" Color="#667085" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Privacidad" FontSize="13" TextColor="#20242A" VerticalOptions="Center" />
                        <Label Grid.Column="2" Text="›" FontSize="16" TextColor="#98A2B3" VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#EEF1F4" />

                    <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <BoxView WidthRequest="12" HeightRequest="12" CornerRadius="6" Color="#667085" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Acerca de JMP" FontSize="13" TextColor="#20242A" VerticalOptions="Center" />
                        <Label Grid.Column="2" Text="›" FontSize="16" TextColor="#98A2B3" VerticalOptions="Center" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- LOGOUT -->
            <Border
                BackgroundColor="#FFFFFF"
                Stroke="#F3D6D2"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                Padding="0">

                <Grid Padding="16,14" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <BoxView WidthRequest="12" HeightRequest="12" CornerRadius="6" Color="#D92D20" VerticalOptions="Center" />
                    <Label
                        Grid.Column="1"
                        Text="Cerrar sesión"
                        FontSize="13"
                        FontAttributes="Bold"
                        TextColor="#D92D20"
                        VerticalOptions="Center" />
                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>