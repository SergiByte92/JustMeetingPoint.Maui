<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="JustMeetinPoint.Maui.Features.Map.Views.MapView"
    Title="Mapa"
    BackgroundColor="#0B57D0">

    <Grid RowDefinitions="*">

        <!-- MAPA FULL SCREEN -->
        <WebView x:Name="MapWebView" />

        <!-- HEADER SUPERIOR -->
        <Grid
            Padding="16,50,16,0"
            VerticalOptions="Start"
            ColumnDefinitions="*,Auto">

            <Border
                BackgroundColor="#EFFFFFFF"
                Stroke="#D2E3FC"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16"
                Padding="14,10">

                <Label
                    Text="{Binding MeetingPointName}"
                    FontSize="16"
                    FontAttributes="Bold"
                    TextColor="#202124"
                    LineBreakMode="TailTruncation" />
            </Border>

            <Border
                Grid.Column="1"
                Margin="12,0,0,0"
                BackgroundColor="#1A73E8"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 16"
                Padding="12,10">

                <Label
                    Text="{Binding DurationText}"
                    FontSize="14"
                    FontAttributes="Bold"
                    TextColor="#FFFFFF" />
            </Border>
        </Grid>

        <!-- BOTTOM SHEET -->
        <Border
            x:Name="BottomSheet"
            VerticalOptions="End"
            BackgroundColor="#F3F4F6"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 24,24,0,0"
            Padding="18,12,18,22"
            HeightRequest="520"
            TranslationY="260">

            <Border.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="OnBottomSheetPanUpdated" />
            </Border.GestureRecognizers>

            <Grid RowDefinitions="Auto,Auto,Auto,*">

                <!-- HANDLE -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Border
                        HorizontalOptions="Center"
                        WidthRequest="52"
                        HeightRequest="6"
                        BackgroundColor="#D2E3FC"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 999" />
                </Grid>

                <!-- RESUMEN -->
                <VerticalStackLayout Grid.Row="1" Spacing="4">
                    <Label
                        Text="{Binding MeetingPointName}"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="#0B57D0" />

                    <Label
                        Text="{Binding SummaryText}"
                        FontSize="14"
                        TextColor="#5F6368" />

                    <Label
                        Text="{Binding TransfersText}"
                        FontSize="13"
                        FontAttributes="Bold"
                        TextColor="#1A73E8" />
                </VerticalStackLayout>

                <!-- MÉTRICAS -->
                <Grid
                    Grid.Row="2"
                    Margin="0,16,0,0"
                    ColumnDefinitions="*,*"
                    ColumnSpacing="12">

                    <Border
                        Grid.Column="0"
                        BackgroundColor="#D2E3FC"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        Padding="14">

                        <VerticalStackLayout Spacing="4">
                            <Label
                                Text="Tiempo estimado"
                                FontSize="12"
                                TextColor="#5F6368" />

                            <Label
                                Text="{Binding DurationText}"
                                FontSize="18"
                                FontAttributes="Bold"
                                TextColor="#0B57D0" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        Grid.Column="1"
                        BackgroundColor="#D2E3FC"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        Padding="14">

                        <VerticalStackLayout Spacing="4">
                            <Label
                                Text="Distancia"
                                FontSize="12"
                                TextColor="#5F6368" />

                            <Label
                                Text="{Binding DistanceText}"
                                FontSize="18"
                                FontAttributes="Bold"
                                TextColor="#0B57D0" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- DETALLE EXPANDIDO -->
                <ScrollView
                    x:Name="ExpandedContent"
                    Grid.Row="3"
                    Margin="0,16,0,0"
                    IsVisible="False">

                    <VerticalStackLayout Spacing="14">

                        <!-- INFO GENERAL -->
                        <Border
                            BackgroundColor="#FFFFFF"
                            Stroke="#E5E7EB"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18"
                            Padding="14">

                            <VerticalStackLayout Spacing="10">

                                <VerticalStackLayout Spacing="2">
                                    <Label
                                        Text="Estado de ruta"
                                        FontSize="12"
                                        TextColor="#5F6368" />

                                    <Label
                                        Text="{Binding AddressText}"
                                        FontSize="15"
                                        FontAttributes="Bold"
                                        TextColor="#202124" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="2">
                                    <Label
                                        Text="Equilibrio grupal"
                                        FontSize="12"
                                        TextColor="#5F6368" />

                                    <Label
                                        Text="{Binding FairnessText}"
                                        FontSize="15"
                                        FontAttributes="Bold"
                                        TextColor="#202124" />
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Border>

                        <!-- ITINERARIO -->
                        <VerticalStackLayout Spacing="8">

                            <Label
                                Text="Itinerario"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="#0B57D0" />

                            <Label
                                Text="No hay detalle de itinerario disponible."
                                FontSize="13"
                                TextColor="#5F6368"
                                IsVisible="{Binding ShowNoItineraryMessage}" />

                            <CollectionView
                                ItemsSource="{Binding Legs}"
                                IsVisible="{Binding HasItinerary}"
                                SelectionMode="None">

                                <CollectionView.ItemTemplate>
                                    <DataTemplate>

                                        <Border
                                            Margin="0,0,0,10"
                                            BackgroundColor="#FFFFFF"
                                            Stroke="#E5E7EB"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 16"
                                            Padding="14">

                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">

                                                <!-- MODO -->
                                                <Border
                                                    WidthRequest="42"
                                                    HeightRequest="42"
                                                    BackgroundColor="#D2E3FC"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 21"
                                                    VerticalOptions="Start">

                                                    <Label
                                                        Text="{Binding Mode}"
                                                        FontSize="10"
                                                        FontAttributes="Bold"
                                                        TextColor="#0B57D0"
                                                        HorizontalOptions="Center"
                                                        VerticalOptions="Center"
                                                        HorizontalTextAlignment="Center" />
                                                </Border>

                                                <!-- CONTENIDO DEL TRAMO -->
                                                <VerticalStackLayout Grid.Column="1" Spacing="4">

                                                    <Label
                                                        Text="{Binding DisplayTitle}"
                                                        FontSize="15"
                                                        FontAttributes="Bold"
                                                        TextColor="#202124" />

                                                    <Label
                                                        Text="{Binding DisplaySubtitle}"
                                                        FontSize="13"
                                                        TextColor="#5F6368" />

                                                    <Label
                                                        Text="{Binding FromName}"
                                                        FontSize="12"
                                                        TextColor="#5F6368"
                                                        LineBreakMode="TailTruncation" />

                                                    <Label
                                                        Text="{Binding ToName}"
                                                        FontSize="12"
                                                        TextColor="#5F6368"
                                                        LineBreakMode="TailTruncation" />

                                                    <Grid
                                                        Margin="0,6,0,0"
                                                        ColumnDefinitions="Auto,Auto"
                                                        ColumnSpacing="10">

                                                        <Label
                                                            Text="{Binding DurationText}"
                                                            FontSize="12"
                                                            FontAttributes="Bold"
                                                            TextColor="#1A73E8" />

                                                        <Label
                                                            Grid.Column="1"
                                                            Text="{Binding DistanceText}"
                                                            FontSize="12"
                                                            FontAttributes="Bold"
                                                            TextColor="#5F6368" />
                                                    </Grid>
                                                </VerticalStackLayout>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Border>
    </Grid>
</ContentPage>