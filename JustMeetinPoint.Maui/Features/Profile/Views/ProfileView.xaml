<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="JustMeetinPoint.Maui.Features.Profile.Views.ProfileView"
    Title="Perfil"
    BackgroundColor="#F3F4F6">

    <ScrollView>
        <VerticalStackLayout Padding="16,18,16,28" Spacing="14">

            <!-- HEADER -->
            <VerticalStackLayout Spacing="4">
                <Label
                    Text="Perfil"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="#0B57D0" />

                <Label
                    Text="Gestiona tu cuenta y preferencias de movilidad."
                    FontSize="13"
                    TextColor="#5F6368" />
            </VerticalStackLayout>

            <!-- CARD USUARIO -->
            <Border
                BackgroundColor="#FFFFFF"
                Stroke="#E5E7EB"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24"
                Padding="18">

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                    <Border
                        WidthRequest="64"
                        HeightRequest="64"
                        BackgroundColor="#D2E3FC"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 32">

                        <Image
                            Source="profile_icon.svg"
                            WidthRequest="32"
                            HeightRequest="32"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                        <Label
                            Text="{Binding FullName}"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="#202124"
                            LineBreakMode="TailTruncation" />

                        <Label
                            Text="{Binding Email}"
                            FontSize="13"
                            TextColor="#5F6368"
                            LineBreakMode="TailTruncation" />

                        <HorizontalStackLayout Spacing="6">
                            <Label Text="●" FontSize="11" TextColor="#188038" />
                            <Label Text="Sesión activa" FontSize="12" TextColor="#188038" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- DATOS DE CUENTA -->
            <Border
                BackgroundColor="#FFFFFF"
                Stroke="#E5E7EB"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24"
                Padding="0">

                <VerticalStackLayout Spacing="0">

                    <VerticalStackLayout Padding="18,16" Spacing="3">
                        <Label
                            Text="Datos de cuenta"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="#202124" />

                        <Label
                            Text="Información vinculada a tu usuario."
                            FontSize="12"
                            TextColor="#5F6368" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="#E5E7EB" />

                    <!-- USERNAME -->
                    <Grid Padding="18,14" ColumnDefinitions="48,*" MinimumHeightRequest="56">
                        <Border
                            WidthRequest="36"
                            HeightRequest="36"
                            BackgroundColor="#D2E3FC"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 18"
                            VerticalOptions="Center">

                            <Image
                                Source="profile_icon.svg"
                                WidthRequest="20"
                                HeightRequest="20"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Nombre de usuario" FontSize="12" TextColor="#5F6368" />
                            <Label Text="{Binding FullName}" FontSize="14" TextColor="#202124" LineBreakMode="TailTruncation" />
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#E5E7EB" Margin="66,0,0,0" />

                    <!-- EMAIL -->
                    <Grid Padding="18,14" ColumnDefinitions="48,*" MinimumHeightRequest="56">
                        <Border
                            WidthRequest="36"
                            HeightRequest="36"
                            BackgroundColor="#D2E3FC"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 18"
                            VerticalOptions="Center">

                            <Image
                                Source="mail_icon.svg"
                                WidthRequest="20"
                                HeightRequest="20"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Email" FontSize="12" TextColor="#5F6368" />
                            <Label Text="{Binding Email}" FontSize="14" TextColor="#202124" LineBreakMode="TailTruncation" />
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#E5E7EB" Margin="66,0,0,0" />

                    <!-- FECHA NACIMIENTO -->
                    <Grid Padding="18,14" ColumnDefinitions="48,*" MinimumHeightRequest="56">
                        <Border
                            WidthRequest="36"
                            HeightRequest="36"
                            BackgroundColor="#D2E3FC"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 18"
                            VerticalOptions="Center">

                            <Image
                                Source="cake_icon.svg"
                                WidthRequest="20"
                                HeightRequest="20"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Fecha de nacimiento" FontSize="12" TextColor="#5F6368" />
                            <Label Text="{Binding BirthDateText}" FontSize="14" TextColor="#202124" />
                        </VerticalStackLayout>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- PREFERENCIAS DE VIAJE -->
            <Border
                BackgroundColor="#FFFFFF"
                Stroke="#E5E7EB"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24"
                Padding="0">

                <VerticalStackLayout Spacing="0">
                    <VerticalStackLayout Padding="18,16" Spacing="3">
                        <Label
                            Text="Preferencias de viaje"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="#202124" />

                        <Label
                            Text="Opciones preparadas para futuras rutas."
                            FontSize="12"
                            TextColor="#5F6368" />
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="#E5E7EB" />

                    <Grid Padding="18,14" ColumnDefinitions="48,*,Auto" MinimumHeightRequest="56">
                        <Image
                            Source="location_icon.svg"
                            WidthRequest="26"
                            HeightRequest="26"
                            VerticalOptions="Center" />

                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Ubicación temporal" FontSize="14" TextColor="#202124" />
                            <Label Text="Solo se usa durante el cálculo del punto." FontSize="12" TextColor="#5F6368" />
                        </VerticalStackLayout>

                        <Label
                            Grid.Column="2"
                            Text="Activa"
                            FontSize="12"
                            TextColor="#188038"
                            VerticalOptions="Center" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#E5E7EB" Margin="66,0,0,0" />

                    <Grid Padding="18,14" ColumnDefinitions="48,*,Auto" MinimumHeightRequest="56">
                        <Image
                            Source="transport_icon.svg"
                            WidthRequest="26"
                            HeightRequest="26"
                            VerticalOptions="Center" />

                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Transporte preferido" FontSize="14" TextColor="#202124" />
                            <Label Text="Disponible en una próxima versión." FontSize="12" TextColor="#5F6368" />
                        </VerticalStackLayout>

                        <Label
                            Grid.Column="2"
                            Text="Próximamente"
                            FontSize="12"
                            TextColor="#5F6368"
                            VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ACTIVIDAD FUTURA -->
            <Border
                BackgroundColor="#FFFFFF"
                Stroke="#E5E7EB"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24"
                Padding="18">

                <VerticalStackLayout Spacing="12">
                    <VerticalStackLayout Spacing="3">
                        <Label
                            Text="Actividad"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="#202124" />

                        <Label
                            Text="Resumen disponible cuando existan datos reales."
                            FontSize="12"
                            TextColor="#5F6368" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Border
                            BackgroundColor="#D2E3FC"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 16"
                            Padding="14">

                            <VerticalStackLayout Spacing="4">
                                <Label Text="Grupos" FontSize="12" TextColor="#5F6368" />
                                <Label Text="{Binding MeetingsCreated}" FontSize="20" FontAttributes="Bold" TextColor="#0B57D0" />
                            </VerticalStackLayout>
                        </Border>

                        <Border
                            Grid.Column="1"
                            BackgroundColor="#D2E3FC"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 16"
                            Padding="14">

                            <VerticalStackLayout Spacing="4">
                                <Label Text="Tiempo medio" FontSize="12" TextColor="#5F6368" />
                                <Label Text="{Binding AvgTravelTimeText}" FontSize="20" FontAttributes="Bold" TextColor="#0B57D0" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ERROR -->
            <Label
                Text="{Binding ErrorMessage}"
                FontSize="12"
                TextColor="#D93025"
                IsVisible="{Binding HasError}"
                Margin="4,0,4,0" />

            <!-- LOGOUT -->
            <Border
                BackgroundColor="#FFFFFF"
                Stroke="#FAD2CF"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 24"
                Padding="0"
                MinimumHeightRequest="56">

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                </Border.GestureRecognizers>

                <Grid
                    Padding="18,16"
                    ColumnDefinitions="48,*"
                    MinimumHeightRequest="56">

                    <Image
                        Source="logout_icon.svg"
                        WidthRequest="24"
                        HeightRequest="24"
                        VerticalOptions="Center"
                        HorizontalOptions="Start" />

                    <Label
                        Grid.Column="1"
                        Text="Cerrar sesión"
                        FontSize="14"
                        FontAttributes="Bold"
                        TextColor="#D93025"
                        VerticalOptions="Center" />
                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>